{
  "expo": {
    "name": "Muslim Go Plus",
    "slug": "dheen-app",
    "version": "1.0.9",

    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A3D2B"
    },
    "plugins": [
      "expo-font",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F6D5B",
          "sounds": [
            "./assets/adhan/azan_makkah.mp3",
            "./assets/adhan/azan_madinah.mp3",
            "./assets/adhan/azan_alaqsa.mp3",
            "./assets/adhan/fajr_bank.mp3"
          ]
        }
      ],
      "expo-sqlite"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A3D2B"
      },
      "package": "com.alrawi.muslimpro",
      "versionCode": 11,

      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "17aa88c4-fd29-4271-a383-08a3bb9bd168"
      }
    }
  }
}
